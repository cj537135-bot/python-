      <aliases enabled='yes' />
      <column caption='Price per ram' datatype='real' name='[Calculation_1029705859893960704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[price(INR)] / [RAM]' />
      </column>
      <column caption='Brand Avg Rating (LOD)' datatype='real' name='[Calculation_1166713804855926784]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [brand] : AVG([rating]) }' />
      </column>
      <column caption='Rating vs Brand Average (Deviation Metric)' datatype='real' name='[Calculation_1166713804856213505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[rating] - [Calculation_1166713804855926784]' />
      </column>
      <column caption='High Rating Flag' datatype='integer' name='[Calculation_1166713804856356866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [rating] &gt;= 4 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_145030006692749312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[rating]' />
      </column>
      <column caption='Value for Money' datatype='real' name='[Calculation_145030006694219777]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[rating] / [price(INR)]' />
      </column>
      <column caption='Price Segment' datatype='string' name='[Calculation_145030006694449154]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [price(INR)] &lt; 15000 THEN &quot;Budget&quot;&#10;ELSEIF [price(INR)] &lt; 30000 THEN &quot;Mid-Range&quot;&#10;ELSE &quot;Premium&quot;&#10;END' />
      </column>
      <column caption='Performance Index' datatype='real' name='[Calculation_145030006694649859]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([RAM] * 0.4) + ([internal memory] * 0.3) + ([rating] * 0.3)' />
      </column>
      <column caption='Select Metric' datatype='real' name='[Calculation_145030006695464964]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;WHEN &quot;Price&quot; THEN [price(INR)]&#10;WHEN &quot;Rating&quot; THEN [rating]&#10;WHEN &quot;Battery&quot; THEN [battery size]&#10;WHEN &quot;RAM&quot; THEN [RAM]&#10;WHEN &quot;Performance Index&quot; THEN [Calculation_145030006694649859]&#10;END' />
      </column>
      <column caption='Within Budget' datatype='string' name='[Calculation_145030006696067077]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [price(INR)] &lt;= [Parameters].[Parameter 2] THEN &quot;Within Budget&quot;&#10;ELSE &quot;Above Budget&quot;&#10;END' />
      </column>
      <column caption='Avg Brand Price' datatype='real' name='[Calculation_145030006696394758]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [brand] : AVG([price(INR)]) }' />
      </column>
